# Health Log — Whoop integration env vars
# Set these in the Netlify dashboard (Site settings → Environment variables).
# They are read by the functions in netlify/functions/.

# Public client ID from developer.whoop.com. Safe to expose; also pasted into
# Settings → Integrations in the app. Used by functions as a safety check.
WHOOP_CLIENT_ID=

# Client secret. NEVER commit or expose to the browser.
WHOOP_CLIENT_SECRET=

# Must match the redirect URI registered in the Whoop developer dashboard.
WHOOP_REDIRECT_URI=https://samhealthlog.netlify.app/whoop-callback
